NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Slide Agent

DATABASE_URL=postgresql://slide_agent:slide_agent@postgres:5432/slide_agent
REDIS_URL=redis://redis:6379

STORAGE_DRIVER=local
STORAGE_ROOT=/app/storage
STORAGE_UPLOADS_DIR=uploads
STORAGE_ASSETS_DIR=assets
STORAGE_EXPORTS_DIR=exports
STORAGE_TEMP_DIR=temporary

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Slide Agent

AUTH_SECRET=
CREDENTIAL_ENCRYPTION_KEY=
DEMO_LOGIN_EMAIL=demo@slide-agent.local
DEMO_LOGIN_PASSWORD=DemoPassword!123

BOOTSTRAP_ADMIN_EMAIL=

DEFAULT_UI_LOCALE=en
DEFAULT_PRESENTATION_LOCALE=en
DEFAULT_CURRENCY=EUR
GLOBAL_MAX_SLIDES=50
GLOBAL_MAX_UPLOAD_MB=100

USD_TO_EUR_EXCHANGE_RATE=0.92

AI_PROVIDER_MODE=mock
AI_MAX_OUTPUT_TOKENS=800

LOG_LEVEL=info
ENABLE_PROMPT_CONTENT_LOGGING=false
WORKER_CONCURRENCY=2
