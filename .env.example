NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Slide Agent

DATABASE_URL=postgresql://slide_agent:slide_agent@postgres:5432/slide_agent
REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_UPLOADS=user-uploads
S3_BUCKET_ASSETS=presentation-assets
S3_BUCKET_EXPORTS=pptx-exports
S3_BUCKET_TEMP=temporary

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Slide Agent

AUTH_SECRET=
CREDENTIAL_ENCRYPTION_KEY=

BOOTSTRAP_ADMIN_EMAIL=

DEFAULT_UI_LOCALE=en
DEFAULT_PRESENTATION_LOCALE=en
DEFAULT_CURRENCY=EUR
GLOBAL_MAX_SLIDES=50
GLOBAL_MAX_UPLOAD_MB=100

USD_TO_EUR_EXCHANGE_RATE=0.92

LOG_LEVEL=info
ENABLE_PROMPT_CONTENT_LOGGING=false
WORKER_CONCURRENCY=2
