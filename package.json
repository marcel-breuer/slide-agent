{
  "name": "slide-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @slide-agent/database prisma:generate",
    "db:migrate": "pnpm --filter @slide-agent/database prisma:migrate",
    "db:seed": "pnpm --filter @slide-agent/database prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.4",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
