{
  "name": "slide-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @slide-agent/database prisma:generate",
    "db:migrate": "pnpm --filter @slide-agent/database prisma:migrate",
    "db:seed": "pnpm --filter @slide-agent/database prisma:seed"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@typescript-eslint/eslint-plugin": "8.32.1",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.4",
    "prettier": "3.4.2",
    "turbo": "2.10.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
