{
  "name": "@slide-agent/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm prisma:generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@slide-agent/presentation-schema": "workspace:*",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "tsx": "4.22.5"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  }
}
